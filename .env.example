PORT=8787
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_RESPONSES_PATH=/v1/responses
UPSTREAM_API_KEY=replace-me
# Optional comma-separated credential pool. Falls back to UPSTREAM_API_KEY.
# UPSTREAM_API_KEYS=replace-me-1,replace-me-2
# Comma-separated SHA-256 hashes of user gateway keys. Never store plaintext keys here.
GATEWAY_KEY_HASHES=
# Optional SHA-256 hashes for the read-only /admin dashboard. Never reuse a gateway key.
ADMIN_KEY_HASHES=
REQUESTS_PER_MINUTE=30
MAX_CONCURRENT_REQUESTS=2
UPSTREAM_TIMEOUT_MS=300000
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://connector:replace-me@127.0.0.1:5432/connector
REDIS_URL=redis://127.0.0.1:6379
