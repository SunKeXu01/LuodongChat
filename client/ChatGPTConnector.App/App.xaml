<Application x:Class="ChatGPTConnector.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="BrandBrush" Color="#142033"/>
    <SolidColorBrush x:Key="BrandHoverBrush" Color="#1D2B40"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#12B8A6"/>
    <SolidColorBrush x:Key="TextBrush" Color="#101828"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#667085"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#DDE3EC"/>
    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="46"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="White"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Triggers><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/><Setter Property="BorderThickness" Value="2"/></Trigger></Style.Triggers>
    </Style>
    <Style x:Key="WatermarkTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="InputBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <Grid>
                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                <TextBlock x:Name="Watermark" Text="{TemplateBinding Tag}" Foreground="#98A2B3"
                           Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="Text" Value=""><Setter TargetName="Watermark" Property="Visibility" Value="Visible"/></Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="Watermark" Property="Visibility" Value="Collapsed"/><Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/><Setter TargetName="InputBorder" Property="BorderThickness" Value="2"/></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter TargetName="InputBorder" Property="Opacity" Value="0.6"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="46"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="White"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Triggers><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/><Setter Property="BorderThickness" Value="2"/></Trigger></Style.Triggers>
    </Style>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="Background" Value="{StaticResource BrandBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.88"/></Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.72"/></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Chrome" Property="Opacity" Value="0.55"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#EAF8F6"/>
      <Setter Property="Foreground" Value="#08786C"/>
    </Style>
    <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinHeight" Value="24"/><Setter Property="Padding" Value="4,2"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#08786C"/>
    </Style>
    <Style x:Key="InlineButton" TargetType="Button" BasedOn="{StaticResource LinkButton}">
      <Setter Property="Foreground" Value="#475467"/><Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="HeaderButton" TargetType="Button" BasedOn="{StaticResource LinkButton}">
      <Setter Property="Foreground" Value="#475467"/><Setter Property="Padding" Value="10,6"/>
    </Style>
    <Style x:Key="FeatureTag" TargetType="Border">
      <Setter Property="Background" Value="#22344C"/><Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="12,7"/><Setter Property="Margin" Value="0,0,8,8"/>
      <Setter Property="TextElement.Foreground" Value="#DCE6F1"/><Setter Property="TextElement.FontSize" Value="12"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#344054"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,12,0,6"/>
    </Style>
    <Style x:Key="FieldError" TargetType="TextBlock"><Setter Property="Foreground" Value="#B42318"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="2,5,0,0"/><Setter Property="TextWrapping" Value="Wrap"/></Style>
    <Style x:Key="FormError" TargetType="TextBlock" BasedOn="{StaticResource FieldError}"><Setter Property="Margin" Value="2,12,0,0"/></Style>
    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="15,9"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#667085"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabChrome" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabChrome" Property="Background" Value="#EAF8F6"/>
                <Setter Property="Foreground" Value="#101828"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabChrome" Property="Background" Value="#F2F4F7"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Application.Resources>
</Application>
