<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
  <FontFamily x:Key="AppFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
  <sys:Double x:Key="FontSizeCaption">12</sys:Double>
  <sys:Double x:Key="FontSizeBody">14</sys:Double>
  <sys:Double x:Key="FontSizeSubtitle">16</sys:Double>
  <sys:Double x:Key="FontSizeTitle">20</sys:Double>
  <sys:Double x:Key="FontSizeDisplay">28</sys:Double>
</ResourceDictionary>
