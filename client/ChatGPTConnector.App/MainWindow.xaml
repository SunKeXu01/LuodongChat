<Window x:Class="ChatGPTConnector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatGPT 连接器" Width="520" Height="720" MinWidth="360" MinHeight="420"
        Icon="/ChatGPTConnector;component/Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Grid Margin="32,26,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="ChatGPT 连接器" FontSize="26" FontWeight="SemiBold"
                   TextWrapping="Wrap" />
        <StackPanel Grid.Row="1" Margin="0,28,0,0">
            <Ellipse x:Name="StatusDot" Width="18" Height="18" Fill="#9CA3AF" HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="正在检测 Codex 配置…" FontSize="18"
                       HorizontalAlignment="Center" Margin="0,12,0,28" TextAlignment="Center" />
            <Border x:Name="EnrollmentPanel" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock x:Name="EnrollmentTitle" Text="没有密钥？通过邮箱自助领取" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBox x:Name="EmailInput" Height="36" Padding="9,6" ToolTip="邮箱地址" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions>
                        <TextBox x:Name="VerificationCodeInput" Height="36" Padding="9,6" MaxLength="6" ToolTip="6 位验证码" />
                        <Button x:Name="RequestCodeButton" Grid.Column="1" Content="获取验证码" Margin="10,0,0,0" Click="RequestCodeButton_OnClick" />
                    </Grid>
                    <Button x:Name="ClaimKeyButton" Content="验证并领取密钥" Height="38" Margin="0,10,0,0" Click="ClaimKeyButton_OnClick" />
                </StackPanel>
            </Border>
            <TextBlock Text="网关密钥（已有密钥可直接填写）" Margin="0,0,0,6" />
            <PasswordBox x:Name="GatewayKeyInput" Height="38" Padding="10,7"
                         PasswordChanged="GatewayKeyInput_OnPasswordChanged" />
            <Button x:Name="EnableButton" Content="开启连接" Height="52" FontSize="17"
                    Margin="0,18,0,0" IsEnabled="False" Click="EnableButton_OnClick" />
            <Button x:Name="RestoreButton" Content="恢复原配置" Height="42" Margin="0,12,0,0"
                    Click="RestoreButton_OnClick" />
            <Grid x:Name="ActionGrid" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LaunchColumn" />
                    <ColumnDefinition x:Name="InstallColumn" />
                    <ColumnDefinition x:Name="UpdateColumn" />
                </Grid.ColumnDefinitions>
                <Button x:Name="LaunchButton" Content="启动 ChatGPT" Height="42" Margin="0,0,6,0"
                        Click="LaunchButton_OnClick" />
                <Button x:Name="InstallButton" Grid.Column="1" Content="下载 ChatGPT" Height="42" Margin="6,0,6,0"
                        Click="InstallButton_OnClick" />
                <Button x:Name="UpdateButton" Grid.Column="2" Content="检查更新" Height="42" Margin="6,0,0,0"
                        Click="UpdateButton_OnClick" />
            </Grid>
            <TextBlock x:Name="UpdateText" Foreground="#047857" FontSize="12" TextAlignment="Center" Margin="0,7,0,0" />
            <TextBlock Text="修改前会展示摘要，并自动创建可校验备份。"
                       Foreground="#6B7280" TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0" />
            <TextBlock Text="API-Key 模式无需 ChatGPT 账号；账号同步、云端历史等功能可能不可用。"
                       Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,24,0,0">
            <TextBlock Text="网关：https://520skx.com" Foreground="#6B7280" TextWrapping="Wrap" />
            <TextBlock Text="客服：2554798585（QQ）" Foreground="#6B7280" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>
      </Grid>
    </ScrollViewer>
</Window>
