<Window x:Class="ChatGPTConnector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatGPT 连接器" Width="960" Height="700" MinWidth="760" MinHeight="560"
        Icon="/ChatGPTConnector;component/Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display">
  <Grid Background="#F4F7FB">
    <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#111827">
      <Grid Margin="28,30,24,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
          <Border Width="54" Height="54" CornerRadius="14" Background="#1F2937" HorizontalAlignment="Left">
            <Image Source="/ChatGPTConnector;component/Assets/AppIcon.png" Margin="7"/>
          </Border>
          <TextBlock Text="ChatGPT 连接器" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,18,0,5"/>
          <TextBlock Text="安全连接 · 跨端同步" Foreground="#9CA3AF"/>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
          <TextBlock Text="GPT-5.6" Foreground="White" FontSize="30" FontWeight="SemiBold"/>
          <TextBlock Text="登录后自动建立受管 Codex 环境。退出软件后恢复原有配置。" Foreground="#C7D2FE" TextWrapping="Wrap" LineHeight="22" Margin="0,12,0,0"/>
          <Border Background="#1F2937" CornerRadius="10" Padding="14" Margin="0,22,0,0">
            <StackPanel>
              <TextBlock Text="• 账号与网关凭据隔离" Foreground="#D1D5DB"/>
              <TextBlock Text="• Windows / Android 同步" Foreground="#D1D5DB" Margin="0,8,0,0"/>
              <TextBlock Text="• 自动更新与配置恢复" Foreground="#D1D5DB" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Grid.Row="2">
          <TextBlock Text="客服：2554798585（QQ）" Foreground="#9CA3AF"/>
          <TextBlock Text="https://520skx.com" Foreground="#6B7280" Margin="0,5,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="36,26,36,28">
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="账户中心" FontSize="24" FontWeight="SemiBold"/>
          <TextBlock Text="使用邮箱安全登录并管理连接" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>
        <Border DockPanel.Dock="Right" Background="#E8F7EF" CornerRadius="14" Padding="12,6" VerticalAlignment="Center">
          <TextBlock Text="服务在线" Foreground="#067647" FontWeight="SemiBold"/>
        </Border>
      </DockPanel>

      <Border x:Name="UpdateBanner" Grid.Row="1" Visibility="Collapsed" Background="#FFF7E8" BorderBrush="#F7B955"
              BorderThickness="1" CornerRadius="10" Padding="14,11" Margin="0,18,0,0">
        <DockPanel LastChildFill="True">
          <Button x:Name="GlobalUpdateButton" DockPanel.Dock="Right" Content="立即更新" MinWidth="96" Height="36"
                  Margin="16,0,0,0" Click="GlobalUpdateButton_OnClick"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="发现客户端新版本" FontWeight="SemiBold" Foreground="#7A2E0E"/>
            <TextBlock x:Name="GlobalUpdateText" Foreground="#9A3412" Margin="0,3,0,0" TextWrapping="Wrap"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <Border x:Name="LoginPanel" Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
              CornerRadius="14" Padding="30" MaxWidth="500" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel>
          <TextBlock Text="欢迎使用" FontSize="25" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          <TextBlock Text="已有账户可直接使用密码登录；注册或设置密码时需要验证邮箱。" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,20"/>
          <TabControl x:Name="AuthTabs" BorderThickness="0" Background="Transparent">
            <TabItem Header="密码登录">
              <StackPanel Margin="4,12,4,2">
                <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="LoginEmailInput" MaxLength="254"/>
                <TextBlock Text="密码" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="LoginPasswordInput" MaxLength="128"/>
                <Button x:Name="PasswordLoginButton" Content="登录" Height="44" Margin="0,18,0,0" Click="PasswordLoginButton_OnClick"/>
                <TextBlock Text="忘记密码？切换到“注册 / 重置密码”，验证邮箱后重新设置。" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
              </StackPanel>
            </TabItem>
            <TabItem Header="注册 / 重置密码">
              <StackPanel Margin="4,12,4,2">
                <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="RegisterEmailInput" MaxLength="254"/>
                <TextBlock Text="密码" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="RegisterPasswordInput" MaxLength="128"/>
                <TextBlock Text="确认密码" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="RegisterConfirmPasswordInput" MaxLength="128"/>
                <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="RegisterCodeInput" MaxLength="6"/>
                  <Button x:Name="RegisterCodeButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="RegisterCodeButton_OnClick"/>
                </Grid>
                <Button x:Name="RegisterButton" Content="注册新账号" Height="44" Margin="0,18,0,0" Click="RegisterButton_OnClick"/>
                <Button x:Name="ResetPasswordButton" Content="已有账号，重置密码" Height="40" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" Click="ResetPasswordButton_OnClick"/>
              </StackPanel>
            </TabItem>
            <TabItem Header="验证码登录">
              <StackPanel Margin="4,12,4,2">
                <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CodeLoginEmailInput" MaxLength="254"/>
                <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="CodeLoginCodeInput" MaxLength="6"/>
                  <Button x:Name="CodeLoginSendButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="CodeLoginSendButton_OnClick"/>
                </Grid>
                <Button x:Name="CodeLoginButton" Content="使用验证码登录" Height="44" Margin="0,18,0,0" Click="CodeLoginButton_OnClick"/>
              </StackPanel>
            </TabItem>
          </TabControl>
          <TextBlock x:Name="AuthNotice" Foreground="#067647" TextAlignment="Center" TextWrapping="Wrap" Margin="0,14,0,0"/>
        </StackPanel>
      </Border>

      <TabControl x:Name="AccountPanel" Grid.Row="2" Margin="0,20,0,0" Visibility="Collapsed" Background="White" BorderBrush="{StaticResource BorderBrush}">
        <TabItem Header="首页">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34,34" MaxWidth="560" HorizontalAlignment="Center">
              <Border Background="#EEF4FF" CornerRadius="50" Width="72" Height="72">
                <Ellipse x:Name="StatusDot" Width="22" Height="22" Fill="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="StatusText" Text="正在建立本地连接…" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,18,0,6"/>
              <TextBlock Text="AI 模型：GPT-5.6" TextAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,24"/>
              <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="18">
                <TextBlock Text="保持连接器运行并处于登录状态，Codex 才能使用此连接。退出登录或退出软件后将自动恢复原始 Codex 环境。" TextWrapping="Wrap" Foreground="#475467" LineHeight="22"/>
              </Border>
              <Button x:Name="ReconnectButton" Content="重新建立连接" Height="44" Margin="0,20,0,0" Click="ReconnectButton_OnClick"/>
              <Button x:Name="UpdateButton" Content="检查客户端更新" Height="42" Margin="0,12,0,0" Style="{StaticResource SecondaryButton}" Click="UpdateButton_OnClick"/>
              <TextBlock x:Name="UpdateText" Foreground="#067647" TextAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
        <TabItem Header="聊天">
          <Grid Margin="22">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <DockPanel><TextBlock Text="GPT-5.6" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/><Button x:Name="NewChatButton" Content="新建会话" HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}" Click="NewChatButton_OnClick"/></DockPanel>
            <ListBox x:Name="ChatMessagesList" Grid.Row="1" Margin="0,16" BorderThickness="0" Background="#F8FAFC" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate><DataTemplate><Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="9" Padding="13" Margin="8,5" MaxWidth="560" HorizontalAlignment="Stretch"><StackPanel><TextBlock Text="{Binding Sender}" FontWeight="SemiBold" Foreground="#1D4ED8"/><TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="ChatNotice" Grid.Row="2" Foreground="#B42318" TextWrapping="Wrap" Margin="2,0,2,7"/>
            <Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBox x:Name="ChatInput" MinHeight="46" MaxHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/><Button x:Name="ChatSendButton" Grid.Column="1" Content="发送" Margin="10,0,0,0" Click="ChatSendButton_OnClick"/></Grid>
          </Grid>
        </TabItem>
        <TabItem Header="个人">
          <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34" MaxWidth="480" HorizontalAlignment="Center"><Border Width="110" Height="110" CornerRadius="55" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" HorizontalAlignment="Center" ClipToBounds="True"><Image x:Name="AvatarImage" Stretch="UniformToFill"/></Border><Button x:Name="UploadAvatarButton" Content="上传头像" Width="120" Margin="0,12,0,20" HorizontalAlignment="Center" Style="{StaticResource SecondaryButton}" Click="UploadAvatarButton_OnClick"/><TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/><TextBlock x:Name="ProfileEmailText" FontSize="16" Margin="0,2,0,12" TextWrapping="Wrap"/><TextBlock Text="网名" Style="{StaticResource FieldLabel}"/><TextBox x:Name="NicknameInput" MaxLength="20"/><Button x:Name="SaveProfileButton" Content="保存个人资料" Height="42" Margin="0,14,0,0" Click="SaveProfileButton_OnClick"/><Button x:Name="LogoutButton" Content="退出登录" Height="42" Margin="0,24,0,0" Background="#FEE4E2" Foreground="#B42318" Click="LogoutButton_OnClick"/></StackPanel></ScrollViewer>
        </TabItem>
        <TabItem Header="消费">
          <StackPanel Margin="38" MaxWidth="560"><TextBlock Text="账户余额" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="BalanceText" Text="¥0.00" FontSize="36" FontWeight="SemiBold" Margin="0,6,0,22"/><Border Background="#FFF7ED" CornerRadius="10" Padding="18"><TextBlock Text="消费流水功能正在建设中，正式启用计费前不会扣除余额。" Foreground="#9A3412" TextWrapping="Wrap"/></Border></StackPanel>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</Window>
