<Window x:Class="ChatGPTConnector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="泺栋 Chat" Width="1200" Height="780" MinWidth="960" MinHeight="680"
        Icon="/LuodongChat;component/Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display">
  <Grid Background="#F5F7FA">
    <Grid.RowDefinitions>
      <RowDefinition Height="64"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
      <Grid Margin="22,0">
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="10" Background="#111827">
            <Image Source="/LuodongChat;component/Assets/AppIcon.png" Margin="5"/>
          </Border>
          <TextBlock Text="泺栋 Chat" FontSize="19" FontWeight="SemiBold" VerticalAlignment="Center" Margin="11,0,0,0"/>
        </StackPanel>
        <Button x:Name="HelpButton" Grid.Column="1" Content="?  帮助与反馈" Style="{StaticResource HeaderButton}"
                VerticalAlignment="Center" Click="HelpButton_OnClick"/>
      </Grid>
    </Border>

    <Border x:Name="UpdateBanner" Grid.Row="1" Visibility="Collapsed" Background="#FFF8EB"
            BorderBrush="#F7C873" BorderThickness="0,0,0,1" Padding="22,10">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="正在准备更新" FontWeight="SemiBold" Foreground="#854D0E" Margin="0,0,10,0"/>
        <TextBlock x:Name="GlobalUpdateText" Foreground="#92400E" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid x:Name="LoginPanel" Background="#F5F7FA">
        <Border Margin="28,24" CornerRadius="24" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="42,34" CornerRadius="24,0,0,24" Background="#142033">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel>
                  <TextBlock Text="登录即用的 AI 对话助手" Foreground="White" FontSize="30" FontWeight="SemiBold"/>
                  <TextBlock Text="自动联网、支持图片生成，历史对话仅保存在本机。" Foreground="#B8C5D6" FontSize="14" Margin="0,9,0,0"/>
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,18,0,0">
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="联网搜索"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="图片生成"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="多会话"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="本地历史"/></Border>
                </WrapPanel>

                <Border Grid.Row="2" Margin="0,24,0,0" Padding="18" CornerRadius="18" Background="#F8FAFC">
                  <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Width="30" Height="30" CornerRadius="9" Background="#142033"><TextBlock Text="AI" Foreground="#74E2D4" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="新对话" FontWeight="SemiBold" Foreground="#101828"/><TextBlock Text="GPT-5.6" FontSize="11" Foreground="#667085"/></StackPanel><Border Grid.Column="2" Background="#EAF8F6" CornerRadius="10" Padding="9,5"><TextBlock Text="● 已联网" Foreground="#08786C" FontSize="11"/></Border></Grid>
                    <StackPanel Grid.Row="1" Margin="0,16,0,12">
                      <Grid Margin="64,0,0,10"><Border Padding="13,10" CornerRadius="14" Background="#E7F0FF"><TextBlock Text="搜索今天值得关注的科技新闻，并生成一张配图。" Foreground="#25324A" FontSize="12" TextWrapping="Wrap"/></Border></Grid>
                      <Grid Margin="0,0,34,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="26" Height="26" CornerRadius="13" Background="#142033" VerticalAlignment="Top"><TextBlock Text="AI" Foreground="#74E2D4" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><Border Grid.Column="1" Margin="8,0,0,0" Padding="13,10" CornerRadius="14" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"><StackPanel><TextBlock Text="正在联网搜索并整理可靠来源…" Foreground="#08786C" FontSize="11"/><TextBlock Text="今天值得关注的方向包括 AI 应用、芯片与智能终端。" Foreground="#344054" FontSize="12" TextWrapping="Wrap" Margin="0,7,0,0"/><Border Margin="0,9,0,0" Padding="10" CornerRadius="10" Background="#EEF8F7"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="84"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="已生成配图" FontWeight="SemiBold" FontSize="11"/><TextBlock Text="科技趋势视觉摘要" Foreground="#667085" FontSize="10" Margin="0,4,0,0"/><TextBlock Text="来源：公开网页 3 条" Foreground="#08786C" FontSize="10" Margin="0,9,0,0"/></StackPanel><Border Grid.Column="1" Height="62" CornerRadius="8"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#19304A"/><GradientStop Color="#12B8A6" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="✦" Foreground="White" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid></Border></StackPanel></Border></Grid>
                    </StackPanel>
                    <Border Grid.Row="2" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Padding="13,10"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="输入消息…" Foreground="#98A2B3"/><Border Grid.Column="1" Background="#142033" CornerRadius="8" Padding="12,5"><TextBlock Text="发送" Foreground="White" FontSize="11"/></Border></Grid></Border>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="40,32" CornerRadius="0,24,24,0" Background="White">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid VerticalAlignment="Center">
                  <StackPanel x:Name="LoginFormsPanel">
                    <StackPanel x:Name="PasswordLoginPanel">
                      <TextBlock Text="欢迎回来" FontSize="29" FontWeight="SemiBold"/>
                      <TextBlock Text="使用邮箱登录，继续你的对话" Foreground="#667085" Margin="0,7,0,18"/>
                      <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                      <TextBox x:Name="LoginEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="LoginEmailInput_OnTextChanged" KeyDown="LoginInput_OnKeyDown"/>
                      <TextBlock x:Name="LoginEmailError" Style="{StaticResource FieldError}"/>
                      <TextBlock Text="密码" Style="{StaticResource FieldLabel}"/>
                      <Grid>
                        <PasswordBox x:Name="LoginPasswordInput" Height="52" MaxLength="128" Padding="12,8,54,8" KeyDown="LoginInput_OnKeyDown" PasswordChanged="LoginPasswordInput_OnPasswordChanged"/>
                        <TextBox x:Name="LoginPasswordRevealInput" Height="52" MaxLength="128" Visibility="Collapsed" Padding="12,8,54,8" KeyDown="LoginInput_OnKeyDown" TextChanged="LoginPasswordRevealInput_OnTextChanged"/>
                        <Button x:Name="PasswordRevealButton" Content="◉" ToolTip="显示密码" HorizontalAlignment="Right" Width="44" Margin="0,5,5,5" FontSize="17" Style="{StaticResource InlineButton}" Click="PasswordRevealButton_OnClick"/>
                      </Grid>
                      <TextBlock x:Name="CapsLockNotice" Text="大写锁定已开启" Foreground="#B54708" FontSize="12" Margin="2,5,0,0" Visibility="Collapsed"/>
                      <TextBlock x:Name="LoginPasswordError" Style="{StaticResource FieldError}"/>
                      <TextBlock x:Name="AuthError" Style="{StaticResource FormError}"/>
                      <Button x:Name="PasswordLoginButton" Content="登录" Height="54" Margin="0,24,0,0" Click="PasswordLoginButton_OnClick"/>
                      <Button Content="使用邮箱验证码登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,13,0,0" Click="ShowCodeLoginButton_OnClick"/>
                      <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><TextBlock Text="没有账号？" Foreground="#667085" VerticalAlignment="Center"/><Button Content="注册账号" Style="{StaticResource LinkButton}" Click="ShowRegisterButton_OnClick"/></StackPanel><Button Grid.Column="2" Content="忘记密码" Style="{StaticResource LinkButton}" Click="ShowResetPasswordButton_OnClick"/></Grid>
                    </StackPanel>

                    <StackPanel x:Name="CodeLoginPanel" Visibility="Collapsed">
                      <Button Content="← 返回密码登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,0,0,12" Click="BackToPasswordLoginButton_OnClick"/>
                      <TextBlock Text="邮箱验证码登录" FontSize="27" FontWeight="SemiBold"/>
                      <TextBlock Text="验证码将发送到你的邮箱" Foreground="#667085" Margin="0,7,0,18"/>
                      <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                      <TextBox x:Name="CodeLoginEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="CodeLoginEmailInput_OnTextChanged"/>
                      <TextBlock x:Name="CodeLoginEmailError" Style="{StaticResource FieldError}"/>
                      <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/>
                      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions><TextBox x:Name="CodeLoginCodeInput" Height="52" MaxLength="6" KeyDown="CodeLoginInput_OnKeyDown"/><Button x:Name="CodeLoginSendButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="CodeLoginSendButton_OnClick"/></Grid>
                      <TextBlock x:Name="CodeLoginError" Style="{StaticResource FormError}"/>
                      <Button x:Name="CodeLoginButton" Content="登录" Height="54" Margin="0,24,0,0" Click="CodeLoginButton_OnClick"/>
                      <StackPanel Orientation="Horizontal" Margin="0,12,0,0"><TextBlock Text="没有账号？" Foreground="#667085" VerticalAlignment="Center"/><Button Content="注册账号" Style="{StaticResource LinkButton}" Click="ShowRegisterButton_OnClick"/></StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="AuthNotice" Foreground="#067647" TextWrapping="Wrap" Margin="0,12,0,0"/>
                  </StackPanel>

                  <StackPanel x:Name="AccountActionPanel" Visibility="Collapsed">
                    <Button Content="← 返回登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,0,0,6" Click="BackToLoginButton_OnClick"/>
                    <TextBlock x:Name="AccountActionTitle" Text="注册账号" FontSize="27" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock x:Name="AccountActionSubtitle" Text="使用邮箱创建你的泺栋 Chat 账号" Foreground="#667085" Margin="0,7,0,10"/>
                    <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RegisterEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="RegisterEmailInput_OnTextChanged"/><TextBlock x:Name="RegisterEmailError" Style="{StaticResource FieldError}"/>
                    <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions><TextBox x:Name="RegisterCodeInput" Height="52" MaxLength="6"/><Button x:Name="RegisterCodeButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="RegisterCodeButton_OnClick"/></Grid>
                    <TextBlock Text="设置密码" Style="{StaticResource FieldLabel}"/><PasswordBox x:Name="RegisterPasswordInput" Height="52" MaxLength="128"/>
                    <TextBlock Text="确认密码" Style="{StaticResource FieldLabel}"/><PasswordBox x:Name="RegisterConfirmPasswordInput" Height="52" MaxLength="128"/>
                    <TextBlock x:Name="AccountActionError" Style="{StaticResource FormError}"/>
                    <Button x:Name="RegisterButton" Content="创建账号" Height="54" Margin="0,20,0,0" Click="RegisterButton_OnClick"/>
                    <Button x:Name="ResetPasswordButton" Content="重置密码" Height="54" Margin="0,20,0,0" Visibility="Collapsed" Click="ResetPasswordButton_OnClick"/>
                  </StackPanel>
                </Grid>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <TabControl x:Name="AccountPanel" Visibility="Collapsed" Background="#FFFFFF" BorderThickness="0" Padding="0">
        <TabItem Header="聊天">
          <Grid Background="#FFFFFF">
            <Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F7F7F8" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
              <Grid Margin="12">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Button x:Name="NewChatButton" Content="＋  新建对话" Height="42" Background="#111827" Margin="0,0,0,10" Click="NewChatButton_OnClick"/>
                <ListBox x:Name="ConversationsList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                         SelectionChanged="ConversationsList_OnSelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="Margin" Value="0,2"/>
                      <Setter Property="Background" Value="Transparent"/>
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="11,10" CornerRadius="9" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.ContextMenu>
                          <ContextMenu><MenuItem Header="删除对话" CommandParameter="{Binding}" Click="DeleteConversationMenuItem_OnClick"/></ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding UpdatedText}" Foreground="#98A2B3" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Grid Grid.Column="1">
              <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
              <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="22,0">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="GPT-5.6" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Button x:Name="CopyCurrentChatButton" Grid.Column="1" Content="复制对话" MinHeight="34" Padding="13,6"
                          Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Click="CopyCurrentChatButton_OnClick"/>
                </Grid>
              </Border>

              <ScrollViewer x:Name="ChatMessagesScroll" Grid.Row="1" Background="#FFFFFF" Padding="18,14"
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                            CanContentScroll="False" Focusable="False">
                <ItemsControl x:Name="ChatMessagesItems">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="4,5">
                        <Border x:Name="MessageBubble" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1"
                                CornerRadius="16" Padding="16,13" MaxWidth="760" HorizontalAlignment="Left">
                          <StackPanel>
                            <TextBlock x:Name="MessageSender" Text="{Binding Sender}" FontWeight="SemiBold" Foreground="#475467"/>
                            <TextBox Text="{Binding Content}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                     TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0" Background="Transparent"
                                     Padding="0" Margin="0,7,0,0" Cursor="IBeam"
                                     HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled"/>
                            <ItemsControl ItemsSource="{Binding Images}" Margin="0,10,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <StackPanel Margin="0,0,0,8">
                                    <Border CornerRadius="12" ClipToBounds="True" Background="#EEF2F6">
                                      <Image Source="{Binding Source}" Tag="{Binding FilePath}" MaxWidth="560" MaxHeight="560"
                                             Stretch="Uniform" Cursor="Hand" ToolTip="点击打开图片"
                                             MouseLeftButtonUp="GeneratedImage_OnMouseLeftButtonUp"/>
                                    </Border>
                                    <Button Content="下载图片" Tag="{Binding FilePath}" HorizontalAlignment="Left"
                                            MinHeight="34" Padding="13,6" Margin="0,8,0,0"
                                            Style="{StaticResource SecondaryButton}" Click="DownloadGeneratedImage_OnClick"/>
                                  </StackPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding Sources}" Margin="0,7,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Button Content="{Binding Title}" Tag="{Binding Url}" ToolTip="{Binding Url}"
                                          HorizontalAlignment="Left" Padding="0,3" Background="Transparent"
                                          Foreground="#155EEF" BorderThickness="0" Click="CitationButton_OnClick"/>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </Grid>
                      <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                          <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right"/>
                          <Setter TargetName="MessageBubble" Property="Background" Value="#E8F2FF"/>
                          <Setter TargetName="MessageBubble" Property="BorderBrush" Value="#C7DCFA"/>
                          <Setter TargetName="MessageSender" Property="Foreground" Value="#175CD3"/>
                        </DataTrigger>
                      </DataTemplate.Triggers>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <TextBlock x:Name="ChatNotice" Grid.Row="2" Foreground="#B42318" TextWrapping="Wrap" Margin="24,4,24,2"/>
              <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="14" Margin="22,10,22,18" Padding="10">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="82"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="ChatInput" MinHeight="48" MaxHeight="140" AcceptsReturn="True" TextWrapping="Wrap"
                           VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" Padding="8"/>
                  <Button x:Name="StopGenerationButton" Grid.Column="1" Content="停止" Visibility="Collapsed" Margin="8,0,0,0"
                          Style="{StaticResource SecondaryButton}" Click="StopGenerationButton_OnClick"/>
                  <Button x:Name="ChatSendButton" Grid.Column="2" Content="发送" Margin="8,0,0,0" Click="ChatSendButton_OnClick"/>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="个人">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34" Width="460" HorizontalAlignment="Center">
              <TextBlock Text="个人资料" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,24"/>
              <Border Width="96" Height="96" CornerRadius="48" BorderBrush="#E5E7EB" BorderThickness="1" HorizontalAlignment="Left" ClipToBounds="True">
                <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
              </Border>
              <Button x:Name="UploadAvatarButton" Content="更换头像" Width="110" Margin="0,10,0,12" HorizontalAlignment="Left"
                      Style="{StaticResource SecondaryButton}" Click="UploadAvatarButton_OnClick"/>
              <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
              <TextBlock x:Name="ProfileEmailText" FontSize="15" Margin="0,2,0,8" TextWrapping="Wrap"/>
              <TextBlock Text="网名" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="NicknameInput" MaxLength="20"/>
              <Button x:Name="SaveProfileButton" Content="保存" Height="42" Margin="0,16,0,0" Click="SaveProfileButton_OnClick"/>
              <Button x:Name="LogoutButton" Content="退出登录" Height="42" Margin="0,12,0,0"
                      Background="#FEE4E2" Foreground="#B42318" Click="LogoutButton_OnClick"/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
  </Grid>
</Window>
