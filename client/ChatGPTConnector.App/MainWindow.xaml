<Window x:Class="ChatGPTConnector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChatGPTConnector.App"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="泺栋 Chat" Width="1200" Height="780" MinWidth="960" MinHeight="680"
        Icon="/LuodongChat;component/Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen" WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown" SizeChanged="MainWindow_OnSizeChanged">
  <Grid Background="{DynamicResource PageBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition x:Name="GlobalTopBarRow" Height="64"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border x:Name="GlobalTopBar" Grid.Row="0" Background="{DynamicResource TopBarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="22,0">
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="10" Background="#111827">
            <Image Source="/LuodongChat;component/Assets/AppIcon.png" Margin="5"/>
          </Border>
          <TextBlock Text="泺栋 Chat" FontSize="19" FontWeight="SemiBold" VerticalAlignment="Center" Margin="11,0,0,0"/>
          <Border x:Name="CurrentVersionPill" Style="{StaticResource VersionPill}" Visibility="Collapsed"
                  Margin="11,0,0,0" VerticalAlignment="Center" ToolTipService.ShowDuration="6000">
            <TextBlock x:Name="CurrentVersionText" VerticalAlignment="Center"/>
          </Border>
          <Button x:Name="VersionUpdateButton" Content="新版本" Style="{StaticResource VersionBadgeButton}"
                  Visibility="Collapsed" Margin="7,0,0,0" Click="VersionUpdateButton_OnClick">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="从 OSS 下载（推荐）" Click="DownloadUpdateFromOss_OnClick"/>
                <MenuItem Header="从 GitHub 下载" Click="DownloadUpdateFromGithub_OnClick"/>
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="ThemeToggleButton" Style="{StaticResource ThemeToggleButton}" Margin="0,0,8,0"
                  ToolTip="选择界面皮肤" AutomationProperties.Name="选择界面皮肤"
                  Click="ThemeToggleButton_OnClick">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem x:Name="LightSkinMenuItem" Header="经典浅色" Tag="Light" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
                <MenuItem x:Name="DarkSkinMenuItem" Header="深夜模式" Tag="Dark" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
                <Separator/>
                <MenuItem x:Name="OceanSkinMenuItem" Header="静谧海蓝" Tag="Ocean" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
                <MenuItem x:Name="VioletSkinMenuItem" Header="暮色紫" Tag="Violet" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
                <MenuItem x:Name="RoseSkinMenuItem" Header="柔雾玫瑰" Tag="Rose" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
                <MenuItem x:Name="EyeCareSkinMenuItem" Header="护眼绿" Tag="EyeCare" IsCheckable="True" Click="SkinMenuItem_OnClick"/>
              </ContextMenu>
            </Button.ContextMenu>
            <ui:SymbolIcon Symbol="PaintBrush20" FontSize="18" Foreground="{DynamicResource ThemeIconBrush}"/>
          </Button>
          <Button x:Name="HelpButton" Style="{StaticResource HeaderButton}"
                  VerticalAlignment="Center" Click="HelpButton_OnClick">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="QuestionCircle20" FontSize="17" Margin="0,0,7,0"/>
              <TextBlock Text="帮助与反馈" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <ui:InfoBar x:Name="UpdateBanner" Grid.Row="1" IsOpen="False" IsClosable="False"
                Severity="Informational" Title="正在准备更新" Margin="14,8"/>

    <Grid Grid.Row="2">
      <Grid x:Name="LoginPanel" Background="{DynamicResource PageBackgroundBrush}">
        <Border Margin="28,24" CornerRadius="24" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="42,34" CornerRadius="24,0,0,24" Background="{DynamicResource LeftPanelBrush}">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel>
                  <TextBlock Text="登录即用的 AI 对话助手" Foreground="White" FontSize="30" FontWeight="SemiBold"/>
                  <TextBlock Text="自动联网、支持图片生成，历史对话仅保存在本机。" Foreground="#B8C5D6" FontSize="14" Margin="0,9,0,0"/>
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,18,0,0">
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="联网搜索"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="图片生成"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="多会话"/></Border>
                  <Border Style="{StaticResource FeatureTag}"><TextBlock Text="本地历史"/></Border>
                </WrapPanel>

                <Border Grid.Row="2" Margin="0,18,0,0" CornerRadius="18" Background="#06182D" ClipToBounds="True">
                  <Image Source="/LuodongChat;component/Assets/HomeHero.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="40,32" CornerRadius="0,24,24,0" Background="{DynamicResource SurfaceBrush}">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid VerticalAlignment="Center">
                  <StackPanel x:Name="LoginFormsPanel">
                    <StackPanel x:Name="PasswordLoginPanel">
                      <TextBlock Text="欢迎回来" FontSize="29" FontWeight="SemiBold"/>
                      <TextBlock Text="使用邮箱登录，继续你的对话" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,18"/>
                      <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                      <TextBox x:Name="LoginEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="LoginEmailInput_OnTextChanged" KeyDown="LoginInput_OnKeyDown"/>
                      <TextBlock x:Name="LoginEmailError" Style="{StaticResource FieldError}"/>
                      <TextBlock Text="密码" Style="{StaticResource FieldLabel}"/>
                      <Grid>
                        <PasswordBox x:Name="LoginPasswordInput" Height="52" MaxLength="128" Padding="12,8,54,8" KeyDown="LoginInput_OnKeyDown" PasswordChanged="LoginPasswordInput_OnPasswordChanged"/>
                        <TextBox x:Name="LoginPasswordRevealInput" Height="52" MaxLength="128" Visibility="Collapsed" Padding="12,8,54,8" KeyDown="LoginInput_OnKeyDown" TextChanged="LoginPasswordRevealInput_OnTextChanged"/>
                        <Button x:Name="PasswordRevealButton" ToolTip="显示密码" HorizontalAlignment="Right" Width="44" Margin="0,5,5,5" FontSize="17" Style="{StaticResource InlineButton}" Click="PasswordRevealButton_OnClick">
                          <ui:SymbolIcon x:Name="PasswordRevealIcon" Symbol="Eye48" FontSize="18"/>
                        </Button>
                      </Grid>
                      <TextBlock x:Name="CapsLockNotice" Text="大写锁定已开启" Foreground="{DynamicResource WarningBrush}" FontSize="12" Margin="2,5,0,0" Visibility="Collapsed"/>
                      <TextBlock x:Name="LoginPasswordError" Style="{StaticResource FieldError}"/>
                      <TextBlock x:Name="AuthError" Style="{StaticResource FormError}"/>
                      <Button x:Name="PasswordLoginButton" Content="登录" Height="54" Margin="0,24,0,0" Click="PasswordLoginButton_OnClick"/>
                      <Button Content="使用邮箱验证码登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,13,0,0" Click="ShowCodeLoginButton_OnClick"/>
                      <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><TextBlock Text="没有账号？" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/><Button Content="注册账号" Style="{StaticResource LinkButton}" Click="ShowRegisterButton_OnClick"/></StackPanel><Button Grid.Column="2" Content="忘记密码" Style="{StaticResource LinkButton}" Click="ShowResetPasswordButton_OnClick"/></Grid>
                    </StackPanel>

                    <StackPanel x:Name="CodeLoginPanel" Visibility="Collapsed">
                      <Button Content="← 返回密码登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,0,0,12" Click="BackToPasswordLoginButton_OnClick"/>
                      <TextBlock Text="邮箱验证码登录" FontSize="27" FontWeight="SemiBold"/>
                      <TextBlock Text="验证码将发送到你的邮箱" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,18"/>
                      <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                      <TextBox x:Name="CodeLoginEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="CodeLoginEmailInput_OnTextChanged"/>
                      <TextBlock x:Name="CodeLoginEmailError" Style="{StaticResource FieldError}"/>
                      <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/>
                      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions><TextBox x:Name="CodeLoginCodeInput" Height="52" MaxLength="6" KeyDown="CodeLoginInput_OnKeyDown"/><Button x:Name="CodeLoginSendButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="CodeLoginSendButton_OnClick"/></Grid>
                      <TextBlock x:Name="CodeLoginError" Style="{StaticResource FormError}"/>
                      <Button x:Name="CodeLoginButton" Content="登录" Height="54" Margin="0,24,0,0" Click="CodeLoginButton_OnClick"/>
                      <StackPanel Orientation="Horizontal" Margin="0,12,0,0"><TextBlock Text="没有账号？" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/><Button Content="注册账号" Style="{StaticResource LinkButton}" Click="ShowRegisterButton_OnClick"/></StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="AuthNotice" Foreground="#067647" TextWrapping="Wrap" Margin="0,12,0,0"/>
                  </StackPanel>

                  <StackPanel x:Name="AccountActionPanel" Visibility="Collapsed">
                    <Button Content="← 返回登录" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,0,0,6" Click="BackToLoginButton_OnClick"/>
                    <TextBlock x:Name="AccountActionTitle" Text="注册账号" FontSize="27" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock x:Name="AccountActionSubtitle" Text="使用邮箱创建你的泺栋 Chat 账号" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,10"/>
                    <TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RegisterEmailInput" Height="52" MaxLength="254" Tag="name@example.com" Style="{StaticResource WatermarkTextBox}" TextChanged="RegisterEmailInput_OnTextChanged"/><TextBlock x:Name="RegisterEmailError" Style="{StaticResource FieldError}"/>
                    <TextBlock Text="邮箱验证码" Style="{StaticResource FieldLabel}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions><TextBox x:Name="RegisterCodeInput" Height="52" MaxLength="6"/><Button x:Name="RegisterCodeButton" Grid.Column="1" Content="获取验证码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="RegisterCodeButton_OnClick"/></Grid>
                    <TextBlock Text="设置密码" Style="{StaticResource FieldLabel}"/><PasswordBox x:Name="RegisterPasswordInput" Height="52" MaxLength="128"/>
                    <TextBlock Text="确认密码" Style="{StaticResource FieldLabel}"/><PasswordBox x:Name="RegisterConfirmPasswordInput" Height="52" MaxLength="128"/>
                    <TextBlock x:Name="AccountActionError" Style="{StaticResource FormError}"/>
                    <Button x:Name="RegisterButton" Content="创建账号" Height="54" Margin="0,20,0,0" Click="RegisterButton_OnClick"/>
                    <Button x:Name="ResetPasswordButton" Content="重置密码" Height="54" Margin="0,20,0,0" Visibility="Collapsed" Click="ResetPasswordButton_OnClick"/>
                  </StackPanel>
                </Grid>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <TabControl x:Name="AccountPanel" Visibility="Collapsed" Background="{DynamicResource SurfaceBrush}" BorderThickness="0" Padding="0">
        <TabControl.Template>
          <ControlTemplate TargetType="TabControl">
            <ContentPresenter ContentSource="SelectedContent"/>
          </ControlTemplate>
        </TabControl.Template>
        <TabItem Header="聊天">
          <Grid x:Name="ChatPageGrid" Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
            <Grid.ColumnDefinitions><ColumnDefinition x:Name="SidebarColumn" Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border x:Name="ChatSidebar" Grid.Column="0" Width="280" Panel.ZIndex="50"
                    Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
              <Grid Margin="10,10,10,8">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid Margin="2,0,2,9">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <Border Width="32" Height="32" CornerRadius="9" Background="#111827" VerticalAlignment="Center">
                    <Image Source="/LuodongChat;component/Assets/AppIcon.png" Margin="4"/>
                  </Border>
                  <TextBlock Grid.Column="1" Text="泺栋 Chat" FontSize="15.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="9,0,0,0" TextWrapping="NoWrap"/>
                  <Button x:Name="SidebarVersionStatusButton" Grid.Column="2" Height="24" MinHeight="24" MinWidth="0" MaxWidth="112"
                          Padding="8,0" Margin="6,0,3,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                          Style="{StaticResource VersionBadgeButton}" Background="{DynamicResource CurrentVersionPillBrush}"
                          Foreground="{DynamicResource VersionPillTextBrush}" Visibility="Collapsed"
                          Click="SidebarVersionStatusButton_OnClick">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <TextBlock x:Name="SidebarVersionStatusText" Text="v2.0.6" FontSize="10.5" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                      <Ellipse x:Name="SidebarVersionUpdateDot" Grid.Column="1" Width="7" Height="7" Margin="5,0,0,0" Fill="#F79009" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </Grid>
                    <Button.ContextMenu><ContextMenu>
                      <MenuItem x:Name="SidebarCurrentVersionMenuItem" Header="当前版本" IsEnabled="False"/>
                      <MenuItem x:Name="SidebarAvailableVersionMenuItem" Header="可用版本" IsEnabled="False" Visibility="Collapsed"/>
                      <Separator x:Name="SidebarUpdateMenuSeparator" Visibility="Collapsed"/>
                      <MenuItem x:Name="SidebarRestartUpdateMenuItem" Header="立即安装并重启" Visibility="Collapsed" Click="RestartPreparedUpdate_OnClick"/>
                      <MenuItem x:Name="SidebarDownloadOssMenuItem" Header="从 OSS 下载（推荐）" Visibility="Collapsed" Click="DownloadUpdateFromOss_OnClick"/>
                      <MenuItem x:Name="SidebarDownloadGithubMenuItem" Header="从 GitHub 下载" Visibility="Collapsed" Click="DownloadUpdateFromGithub_OnClick"/>
                    </ContextMenu></Button.ContextMenu>
                  </Button>
                  <Button x:Name="HideSidebarButton" Grid.Column="3" Width="30" Height="30" MinHeight="30" Padding="7" Margin="0,0,2,0"
                          Style="{StaticResource IconToolbarButton}" ToolTip="隐藏侧栏（Ctrl+B）"
                          AutomationProperties.Name="隐藏侧栏" Click="HideSidebarButton_OnClick">
                    <ui:SymbolIcon Symbol="PanelLeftContract20" FontSize="17"/>
                  </Button>
                </Grid>
                <Button x:Name="NewChatButton" Grid.Row="1" Style="{StaticResource NewChatSidebarButton}" Margin="0,0,0,8"
                        ToolTip="新建会话（Ctrl+Shift+O）" AutomationProperties.Name="新建会话" Click="NewChatButton_OnClick">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="ChatAdd20" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="新建会话" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Ctrl+Shift+O" FontSize="10.5" FontWeight="Normal" Foreground="{DynamicResource WeakTextBrush}" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
                <Grid Grid.Row="2" Margin="0,0,0,7">
                  <TextBox x:Name="ConversationSearchInput" Height="36" MinHeight="36" Tag="搜索对话" Padding="33,6,12,6"
                           Style="{StaticResource WatermarkTextBox}" TextChanged="ConversationSearchInput_OnTextChanged"/>
                  <ui:SymbolIcon Symbol="Search12" FontSize="15" Foreground="{DynamicResource MutedBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                </Grid>
                <ListBox x:Name="ConversationsList" Grid.Row="3" BorderThickness="0" Background="Transparent"
                         SelectionChanged="ConversationsList_OnSelectionChanged"
                         PreviewKeyDown="ConversationsList_OnPreviewKeyDown"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.GroupStyle>
                    <GroupStyle>
                      <GroupStyle.HeaderTemplate>
                        <DataTemplate><TextBlock Text="{Binding Name}" Foreground="{DynamicResource WeakTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="7,12,0,5"/></DataTemplate>
                      </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                  </ListBox.GroupStyle>
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="Margin" Value="0,1"/>
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border x:Name="ConversationCard" Height="40" Padding="10,0" CornerRadius="8" Background="Transparent" BorderThickness="0"
                              ToolTip="{Binding Title}" MouseLeftButtonDown="ConversationCard_OnMouseLeftButtonDown">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="重命名" CommandParameter="{Binding}" Click="RenameConversationMenuItem_OnClick"/>
                            <Separator/>
                            <MenuItem Header="删除对话" CommandParameter="{Binding}" Click="DeleteConversationMenuItem_OnClick"/>
                          </ContextMenu>
                        </Border.ContextMenu>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Title}" FontWeight="Normal" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                     AutomationProperties.Name="{Binding Title}"/>
                          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="ConversationActivityText" Text="{Binding ActivityText}"
                                       Visibility="{Binding ActivityVisibility}" Foreground="{DynamicResource LinkBrush}"
                                       FontSize="11" Margin="7,1,3,0" ToolTip="{Binding ActivityToolTip}"/>
                            <TextBlock x:Name="ConversationUpdatedText" Text="{Binding UpdatedText}" Visibility="Collapsed" Foreground="{DynamicResource WeakTextBrush}" FontSize="11" Margin="8,1,3,0"/>
                            <Button x:Name="ConversationMoreButton" Tag="{Binding}" Visibility="Collapsed" Width="28" Height="28" MinHeight="28" Padding="6"
                                    Style="{StaticResource IconToolbarButton}" ToolTip="更多操作" AutomationProperties.Name="会话更多操作"
                                    Click="ConversationMoreButton_OnClick">
                              <ui:SymbolIcon Symbol="MoreHorizontal20" FontSize="15"/>
                              <Button.ContextMenu><ContextMenu>
                                <MenuItem Header="重命名" Click="RenameConversationMenuItem_OnClick"/>
                                <Separator/>
                                <MenuItem Header="删除对话" Click="DeleteConversationMenuItem_OnClick"/>
                              </ContextMenu></Button.ContextMenu>
                            </Button>
                          </StackPanel>
                        </Grid>
                      </Border>
                      <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                          <Setter TargetName="ConversationCard" Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ActivityStatus}" Value="Failed">
                          <Setter TargetName="ConversationActivityText" Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ActivityStatus}" Value="Stopped">
                          <Setter TargetName="ConversationActivityText" Property="Foreground" Value="{DynamicResource WeakTextBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                          <Setter TargetName="ConversationCard" Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
                          <Setter TargetName="ConversationUpdatedText" Property="Visibility" Value="Visible"/>
                          <Setter TargetName="ConversationMoreButton" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </DataTemplate.Triggers>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Grid Grid.Row="4" Margin="0,7,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <Button x:Name="ProfileSidebarButton" Style="{StaticResource SidebarAccountButton}" Click="ProfileSidebarButton_OnClick">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentBrush}" ClipToBounds="True">
                      <Grid>
                        <TextBlock x:Name="SidebarAvatarFallbackText" Text="我" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <Image x:Name="SidebarAvatarImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                      </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="9,0,6,0" VerticalAlignment="Center">
                      <TextBlock x:Name="SidebarProfileName" Text="个人资料" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </Grid>
                  </Button>
                  <Button x:Name="SidebarMoreButton" Grid.Column="1" Width="36" Height="36" MinHeight="36" Padding="8" Style="{StaticResource IconToolbarButton}"
                          ToolTip="账号与应用设置" AutomationProperties.Name="账号与应用设置" Click="SidebarMoreButton_OnClick">
                    <ui:SymbolIcon Symbol="MoreHorizontal20" FontSize="17"/>
                  </Button>
                  <Popup x:Name="SidebarMenuPopup" PlacementTarget="{Binding ElementName=SidebarMoreButton}" Placement="Top"
                         StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-176" VerticalOffset="-8">
                    <Border Width="218" Padding="6" CornerRadius="12" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                      <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.16" Color="#0F172A"/></Border.Effect>
                      <Grid>
                        <StackPanel x:Name="SidebarMenuRoot">
                          <Button Style="{StaticResource SidebarMenuButton}" Click="ProfileSidebarButton_OnClick">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/></Grid.ColumnDefinitions><ui:SymbolIcon Symbol="PersonCircle20" FontSize="18" Foreground="{DynamicResource MutedBrush}"/><TextBlock Grid.Column="1" Text="个人资料" VerticalAlignment="Center"/></Grid>
                          </Button>
                          <Button Style="{StaticResource SidebarMenuButton}" Click="OpenThemePanel_OnClick">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:SymbolIcon Symbol="PaintBrush20" FontSize="18" Foreground="{DynamicResource MutedBrush}"/><TextBlock Grid.Column="1" Text="外观主题" VerticalAlignment="Center"/><ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight20" FontSize="15" Foreground="{DynamicResource WeakTextBrush}"/></Grid>
                          </Button>
                          <Button Style="{StaticResource SidebarMenuButton}" Click="HelpButton_OnClick">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/></Grid.ColumnDefinitions><ui:SymbolIcon Symbol="QuestionCircle20" FontSize="18" Foreground="{DynamicResource MutedBrush}"/><TextBlock Grid.Column="1" Text="帮助与反馈" VerticalAlignment="Center"/></Grid>
                          </Button>
                          <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="8,5"/>
                          <Button Style="{StaticResource DangerSidebarMenuButton}" Click="LogoutButton_OnClick">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/></Grid.ColumnDefinitions><ui:SymbolIcon Symbol="SignOut20" FontSize="18"/><TextBlock Grid.Column="1" Text="退出登录" VerticalAlignment="Center"/></Grid>
                          </Button>
                        </StackPanel>
                        <StackPanel x:Name="SidebarThemePanel" Visibility="Collapsed">
                          <Button Style="{StaticResource SidebarMenuButton}" Click="BackToSidebarMenu_OnClick">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="←" FontSize="17" Margin="0,0,9,0"/><TextBlock Text="外观主题" FontWeight="SemiBold" VerticalAlignment="Center"/></StackPanel>
                          </Button>
                          <UniformGrid Columns="2" Margin="0,4,0,0">
                            <Button Tag="Light" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#F4F7FA"/><Border Width="21" Height="16" CornerRadius="4" Background="#142033" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#12B8A6"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="云白 · 浅色"/><TextBlock x:Name="LightThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                            <Button Tag="Dark" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#080E1A"/><Border Width="21" Height="16" CornerRadius="4" Background="#334155" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#2DD4BF"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="墨夜 · 深色"/><TextBlock x:Name="DarkThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                            <Button Tag="Ocean" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#081827"/><Border Width="21" Height="16" CornerRadius="4" Background="#16324B" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#22D3EE"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="深海 · 深色"/><TextBlock x:Name="OceanThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                            <Button Tag="Violet" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#F7F5FF"/><Border Width="21" Height="16" CornerRadius="4" Background="#4C3F91" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#8B5CF6"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="暮紫 · 浅色"/><TextBlock x:Name="VioletThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                            <Button Tag="Rose" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#FFF7F8"/><Border Width="21" Height="16" CornerRadius="4" Background="#8E445D" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#E98AA8"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="晨雾玫瑰"/><TextBlock x:Name="RoseThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                            <Button Tag="EyeCare" Style="{StaticResource ThemeCardButton}" Click="SkinMenuItem_OnClick"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Border Width="21" Height="16" CornerRadius="4" Background="#F3F7EF"/><Border Width="21" Height="16" CornerRadius="4" Background="#3F5D46" Margin="4,0"/><Border Width="21" Height="16" CornerRadius="4" Background="#6B9B72"/></StackPanel><Grid Grid.Row="1" Margin="0,7,0,0"><TextBlock Text="森屿 · 护眼"/><TextBlock x:Name="EyeCareThemeCheck" Text="✓" HorizontalAlignment="Right" Foreground="{DynamicResource LinkBrush}" Visibility="Collapsed"/></Grid></Grid></Button>
                          </UniformGrid>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Popup>
                </Grid>
              </Grid>
            </Border>

            <Border x:Name="SidebarScrim" Grid.ColumnSpan="2" Panel.ZIndex="40" Visibility="Collapsed"
                    Background="#52000000" MouseLeftButtonDown="SidebarScrim_OnMouseLeftButtonDown"/>

            <Grid x:Name="ChatDropSurface" Grid.Column="1" AllowDrop="True"
                  PreviewDragEnter="ChatComposer_OnDragEnter" PreviewDragOver="ChatComposer_OnDragOver"
                  PreviewDragLeave="ChatComposer_OnDragLeave" PreviewDrop="ChatComposer_OnDrop">
              <Grid.RowDefinitions><RowDefinition Height="0"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
              <Border Visibility="Collapsed" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GPT-5.6" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Margin="12,0,0,0" Padding="9,4" CornerRadius="999" Background="{DynamicResource SecondarySurfaceBrush}">
                      <StackPanel Orientation="Horizontal"><Ellipse Width="7" Height="7" Fill="{DynamicResource AccentBrush}" Margin="0,0,6,0"/><TextBlock x:Name="NetworkStatusText" Text="联网搜索已开启" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/></StackPanel>
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>

              <ScrollViewer x:Name="ChatMessagesScroll" Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="28,18"
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                            HorizontalContentAlignment="Stretch" CanContentScroll="False" Focusable="False"
                            PanningMode="VerticalOnly" IsManipulationEnabled="True"
                            PreviewMouseWheel="ChatMessagesScroll_OnPreviewMouseWheel"
                            ScrollChanged="ChatMessagesScroll_OnScrollChanged">
                <ItemsControl x:Name="ChatMessagesItems" MaxWidth="960" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="{Binding MessageMargin}" HorizontalAlignment="Stretch">
                        <StackPanel x:Name="MessageGroup" MaxWidth="768" HorizontalAlignment="Left" Background="Transparent">
                          <StackPanel x:Name="MessageHeader" Orientation="Horizontal" Margin="2,0,2,6">
                            <Border x:Name="MessageAvatar" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource BrandBrush}"><TextBlock x:Name="MessageAvatarText" Text="AI" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <TextBlock x:Name="MessageSender" Text="{Binding Sender}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                          </StackPanel>
                          <Border x:Name="MessageBubble" MaxWidth="768" HorizontalAlignment="Left"
                                  Background="Transparent" BorderThickness="0" CornerRadius="0" Padding="2,8">
                            <StackPanel>
                            <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,8">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Button Tag="{Binding FilePath}" ToolTip="{Binding Name}" HorizontalContentAlignment="Stretch" Padding="0" Margin="0,0,0,7" Background="Transparent" BorderThickness="0" Click="OpenMessageAttachment_OnClick">
                                    <Grid>
                                      <Border Width="220" Height="140" CornerRadius="12" ClipToBounds="True" HorizontalAlignment="Left" Visibility="{Binding ImageVisibility}" Background="{DynamicResource SecondarySurfaceBrush}">
                                        <Image Source="{Binding Preview}" Stretch="UniformToFill"/>
                                      </Border>
                                      <Border MinWidth="250" MaxWidth="420" Height="64" Padding="10" CornerRadius="11" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource SecondarySurfaceBrush}" Visibility="{Binding FileVisibility}">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                          <Border Width="38" Height="38" CornerRadius="8" Background="{DynamicResource SurfaceBrush}"><TextBlock Text="{Binding IconText}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                          <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center"><TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/><TextBlock Text="{Binding DetailText}" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0"/></StackPanel>
                                        </Grid>
                                      </Border>
                                    </Grid>
                                  </Button>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <local:MarkdownViewer MarkdownText="{Binding Content}" FontSize="15.5" FontWeight="Normal"
                                                  Foreground="{DynamicResource TextBrush}" Background="Transparent"
                                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding ThinkingVisibility}" Margin="1,1,0,2">
                              <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,7,0"
                                               Foreground="{DynamicResource LinkBrush}"/>
                              <TextBlock Text="正在思考，切换到其他对话不会中断" Foreground="{DynamicResource MutedBrush}" FontSize="13"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Images}" Margin="0,10,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <StackPanel Margin="0,0,0,8">
                                    <Border CornerRadius="12" ClipToBounds="True" Background="#EEF2F6">
                                      <Image Source="{Binding Source}" Tag="{Binding FilePath}" MaxWidth="560" MaxHeight="560"
                                             Stretch="Uniform" Cursor="Hand" ToolTip="点击打开图片"
                                             MouseLeftButtonUp="GeneratedImage_OnMouseLeftButtonUp"/>
                                    </Border>
                                    <Button Content="下载图片" Tag="{Binding FilePath}" HorizontalAlignment="Left"
                                            MinHeight="34" Padding="13,6" Margin="0,8,0,0"
                                            Style="{StaticResource SecondaryButton}" Click="DownloadGeneratedImage_OnClick"/>
                                  </StackPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding Sources}" Visibility="{Binding SourcesVisibility}" Margin="0,7,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Button Content="{Binding Title}" Tag="{Binding Url}" ToolTip="{Binding Url}"
                                          HorizontalAlignment="Left" Padding="0,3" Background="Transparent"
                                          Foreground="{DynamicResource LinkBrush}" BorderThickness="0" Click="CitationButton_OnClick"/>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                          </Border>
                          <Grid x:Name="MessageActions" Margin="4,6,4,0" Background="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="MessageTime" Text="{Binding TimeText}" Foreground="{DynamicResource WeakTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="0" x:Name="UserActions" Orientation="Horizontal" Margin="0,0,8,0" Visibility="Collapsed" Opacity="0.42" IsHitTestVisible="True">
                              <Button Tag="{Binding}" Style="{StaticResource IconActionButton}" ToolTip="复制消息" Click="CopyMessageButton_OnClick">
                                <Viewbox Width="15" Height="15"><Path Data="M8,8 H19 V19 H8 Z M5,16 H4 A2,2 0 0 1 2,14 V4 A2,2 0 0 1 4,2 H14 A2,2 0 0 1 16,4 V5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                              </Button>
                            </StackPanel>
                            <StackPanel Grid.Column="1" x:Name="AssistantActions" Orientation="Horizontal" Margin="8,0,0,0" Opacity="0.42" IsHitTestVisible="True">
                              <Button Tag="{Binding}" Style="{StaticResource IconActionButton}" ToolTip="复制回答" Click="CopyMessageButton_OnClick">
                                <Viewbox Width="15" Height="15"><Path Data="M8,8 H19 V19 H8 Z M5,16 H4 A2,2 0 0 1 2,14 V4 A2,2 0 0 1 4,2 H14 A2,2 0 0 1 16,4 V5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                              </Button>
                              <Button Tag="{Binding}" Style="{StaticResource IconActionButton}" ToolTip="重新生成" Click="RegenerateMessageButton_OnClick">
                                <Viewbox Width="16" Height="16"><Path Data="M20,6 V11 H15 M4,18 V13 H9 M6.1,8.2 A7,7 0 0 1 18.6,8.5 L20,11 M4,13 L5.4,15.5 A7,7 0 0 0 17.9,15.8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                              </Button>
                              <Button x:Name="SourcesActionButton" Tag="{Binding}" Style="{StaticResource IconActionButton}" ToolTip="查看来源" Click="ToggleSourcesButton_OnClick">
                                <Viewbox Width="16" Height="16"><Path Data="M10,13 A5,5 0 0 0 17.1,13 L20,10 A5,5 0 0 0 12.9,2.9 L11.2,4.6 M14,11 A5,5 0 0 1 6.9,11 L4,14 A5,5 0 0 0 11.1,21.1 L12.8,19.4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/></Viewbox>
                              </Button>
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </Grid>
                      <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                          <Setter TargetName="MessageGroup" Property="HorizontalAlignment" Value="Right"/>
                          <Setter TargetName="MessageGroup" Property="MaxWidth" Value="560"/>
                          <Setter TargetName="MessageBubble" Property="Width" Value="{Binding BubbleWidth}"/>
                          <Setter TargetName="MessageBubble" Property="MaxWidth" Value="560"/>
                          <Setter TargetName="MessageHeader" Property="Visibility" Value="Collapsed"/>
                          <Setter TargetName="MessageBubble" Property="MinWidth" Value="80"/>
                          <Setter TargetName="MessageBubble" Property="Padding" Value="16,12"/>
                          <Setter TargetName="MessageBubble" Property="CornerRadius" Value="16,8,16,16"/>
                          <Setter TargetName="MessageBubble" Property="BorderThickness" Value="1"/>
                          <Setter TargetName="MessageBubble" Property="Background" Value="{DynamicResource UserMessageBrush}"/>
                          <Setter TargetName="MessageBubble" Property="BorderBrush" Value="{DynamicResource UserMessageBorderBrush}"/>
                          <Setter TargetName="MessageSender" Property="Foreground" Value="{DynamicResource LinkBrush}"/>
                          <Setter TargetName="MessageAvatar" Property="Background" Value="{DynamicResource AccentBrush}"/>
                          <Setter TargetName="MessageAvatarText" Property="Text" Value="你"/>
                          <Setter TargetName="MessageAvatar" Property="ToolTip" Value="你"/>
                          <Setter TargetName="MessageSender" Property="Visibility" Value="Collapsed"/>
                          <Setter TargetName="MessageActions" Property="HorizontalAlignment" Value="Right"/>
                          <Setter TargetName="MessageTime" Property="Grid.Column" Value="1"/>
                          <Setter TargetName="UserActions" Property="Visibility" Value="Visible"/>
                          <Setter TargetName="AssistantActions" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasSources}" Value="False"><Setter TargetName="SourcesActionButton" Property="Visibility" Value="Collapsed"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsNavigationHighlighted}" Value="True">
                          <Setter TargetName="MessageBubble" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                          <Setter TargetName="MessageBubble" Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                        <Trigger SourceName="MessageGroup" Property="IsMouseOver" Value="True">
                          <Setter TargetName="AssistantActions" Property="Opacity" Value="1"/>
                          <Setter TargetName="UserActions" Property="Opacity" Value="1"/>
                        </Trigger>
                      </DataTemplate.Triggers>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Grid x:Name="EmptyConversationPanel" Grid.Row="1" Panel.ZIndex="3" Background="{DynamicResource SurfaceBrush}" Visibility="Visible">
                <StackPanel Width="960" MaxWidth="960" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="28,0,28,90">
                  <TextBlock Text="泺栋 Chat" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="有什么可以帮忙的？" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,15,0,28"/>
                  <UniformGrid Columns="2" Rows="2" HorizontalAlignment="Stretch">
                    <Button Tag="帮我分析一个文件" Content="帮我分析一个文件" Margin="6" Padding="18,14" HorizontalContentAlignment="Left" Style="{StaticResource SecondaryButton}" Click="ConversationSuggestionButton_OnClick"/>
                    <Button Tag="总结下面这段文字" Content="总结一段文字" Margin="6" Padding="18,14" HorizontalContentAlignment="Left" Style="{StaticResource SecondaryButton}" Click="ConversationSuggestionButton_OnClick"/>
                    <Button Tag="生成一张图片" Content="生成一张图片" Margin="6" Padding="18,14" HorizontalContentAlignment="Left" Style="{StaticResource SecondaryButton}" Click="ConversationSuggestionButton_OnClick"/>
                    <Button Tag="联网查找最新资料" Content="联网查找资料" Margin="6" Padding="18,14" HorizontalContentAlignment="Left" Style="{StaticResource SecondaryButton}" Click="ConversationSuggestionButton_OnClick"/>
                  </UniformGrid>
                </StackPanel>
              </Grid>

              <StackPanel x:Name="ConversationActionsPanel" Grid.Row="1" Panel.ZIndex="7" Visibility="Collapsed"
                          Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,24,0">
                <Button x:Name="CopyCurrentChatButton" Style="{StaticResource IconToolbarButton}" ToolTip="复制当前对话" AutomationProperties.Name="复制当前对话" Click="CopyCurrentChatButton_OnClick">
                  <Viewbox Width="18" Height="18"><Path Data="M8,8 H19 V19 H8 Z M5,16 H4 A2,2 0 0 1 2,14 V4 A2,2 0 0 1 4,2 H14 A2,2 0 0 1 16,4 V5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                </Button>
                <Button x:Name="ChatMoreButton" Style="{StaticResource IconToolbarButton}" Margin="4,0,0,0" ToolTip="更多操作" AutomationProperties.Name="更多操作" Click="ChatMoreButton_OnClick">
                  <ui:SymbolIcon Symbol="MoreHorizontal20" FontSize="18"/>
                  <Button.ContextMenu><ContextMenu>
                    <MenuItem Header="导出对话" Click="ExportConversationMenuItem_OnClick"/>
                    <MenuItem Header="清空当前对话" Click="ClearConversationMenuItem_OnClick"/>
                    <Separator/><MenuItem Header="删除会话" Click="DeleteCurrentConversationMenuItem_OnClick"/>
                  </ContextMenu></Button.ContextMenu>
                </Button>
              </StackPanel>

              <Border x:Name="QuestionNavigator" Grid.Row="1" Panel.ZIndex="8" Visibility="Collapsed"
                      Width="44" MaxHeight="520" HorizontalAlignment="Left" VerticalAlignment="Center"
                      Margin="8,18,0,18" Background="Transparent" IsHitTestVisible="True">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl x:Name="QuestionNavigatorItems">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Tag="{Binding}" Width="36" Height="{Binding HitHeight}" MinHeight="0" Padding="0"
                                Background="Transparent" BorderThickness="0" ToolTip="{Binding ToolTipText}"
                                ToolTipService.ShowDuration="12000" AutomationProperties.Name="{Binding AutomationName}"
                                Click="QuestionAnchorButton_OnClick">
                          <Button.Template>
                            <ControlTemplate TargetType="Button">
                              <Grid Background="Transparent">
                                <Border x:Name="AnchorLine" Width="12" Height="3" CornerRadius="2"
                                        Background="{DynamicResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                              </Grid>
                              <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="AnchorLine" Property="Width" Value="20"/>
                                  <Setter TargetName="AnchorLine" Property="Height" Value="4"/>
                                  <Setter TargetName="AnchorLine" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                  <Setter TargetName="AnchorLine" Property="Width" Value="20"/>
                                  <Setter TargetName="AnchorLine" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                  <Setter TargetName="AnchorLine" Property="Width" Value="24"/>
                                  <Setter TargetName="AnchorLine" Property="Height" Value="4"/>
                                  <Setter TargetName="AnchorLine" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                              </ControlTemplate.Triggers>
                            </ControlTemplate>
                          </Button.Template>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>

              <Button x:Name="ReturnToBottomButton" Grid.Row="1" Panel.ZIndex="10" Visibility="Collapsed"
                      Width="38" Height="38" MinHeight="38" Padding="9" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                      Margin="0,0,0,18" Style="{StaticResource IconToolbarButton}" ToolTip="回到底部"
                      AutomationProperties.Name="回到底部" Click="ReturnToBottomButton_OnClick">
                <ui:SymbolIcon Symbol="ArrowDown12" FontSize="17"/>
              </Button>

              <StackPanel Grid.Row="2" MaxWidth="960" HorizontalAlignment="Stretch" Margin="24,3,24,0">
                <Border x:Name="ProjectRequirementNotice" Visibility="Collapsed" Padding="11,8" CornerRadius="10"
                        Background="#FFFFF4E5" BorderBrush="#FFF2C66D" BorderThickness="1" Margin="0,0,0,5">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="此操作需要访问本地文件，请先选择项目空间。" Foreground="#FF8A4B08" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="选择" MinHeight="30" Padding="12,4" Margin="12,0,0,0" Style="{StaticResource SecondaryButton}" Click="ProjectSpaceHintButton_OnClick"/>
                  </Grid>
                </Border>
                <TextBlock x:Name="ChatNotice" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
              </StackPanel>
              <Border x:Name="ChatComposer" Grid.Row="3" MaxWidth="960" MinHeight="104" HorizontalAlignment="Stretch" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="24" Margin="24,10,24,8" Padding="12,10">
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                  <Button x:Name="ProjectSpaceHint" Grid.Row="0" Margin="0,0,0,4" Padding="6,3" HorizontalAlignment="Left"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource MutedBrush}"
                          ToolTip="选择本地文件夹后，GPT 才能按你的权限读取文件或执行操作" Click="ProjectSpaceHintButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0"><Path Data="M3,6 H9 L11,8 H21 V19 A2,2 0 0 1 19,21 H3 A2,2 0 0 1 1,19 V8 A2,2 0 0 1 3,6 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                      <TextBlock Text="未选择项目空间" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <ScrollViewer x:Name="AttachmentPreviewScroll" Grid.Row="1" Visibility="Collapsed" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="2,0,2,8" MaxHeight="106">
                    <ItemsControl x:Name="AttachmentPreviewItems">
                      <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,10,0">
                            <Border x:Name="ImageAttachmentCard" Width="78" Height="78" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource SecondarySurfaceBrush}" ClipToBounds="True" Visibility="{Binding ImageVisibility}">
                              <Grid>
                                <Image Source="{Binding Preview}" Visibility="{Binding PreviewVisibility}" Stretch="UniformToFill" Cursor="Hand" ToolTip="{Binding Name}" Tag="{Binding}" MouseLeftButtonUp="AttachmentPreview_OnClick"/>
                                <StackPanel Visibility="{Binding PreviewPlaceholderVisibility}" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="▧" FontSize="20" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/><TextBlock Text="无法预览" FontSize="10" Foreground="{DynamicResource MutedBrush}"/></StackPanel>
                              </Grid>
                            </Border>
                            <Border x:Name="FileAttachmentCard" Width="300" Height="78" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource SecondarySurfaceBrush}" Visibility="{Binding FileVisibility}" Padding="10">
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition/><ColumnDefinition Width="26"/></Grid.ColumnDefinitions>
                                <Border Width="46" Height="46" CornerRadius="10" Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding IconText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                  <TextBlock Text="{Binding DetailText}" FontSize="11.5" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0"/>
                                  <TextBlock Text="{Binding StatusText}" Visibility="{Binding ErrorVisibility}" FontSize="11" Foreground="{DynamicResource ErrorBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                              </Grid>
                            </Border>
                            <Button Tag="{Binding}" Width="24" Height="24" Padding="5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"
                                    Background="#D91F2937" BorderThickness="0" ToolTip="删除附件" AutomationProperties.Name="{Binding Name, StringFormat=删除附件：{0}}" Click="RemoveAttachmentButton_OnClick">
                              <Viewbox Width="10" Height="10"><Path Data="M4,4 L20,20 M20,4 L4,20" Stroke="White" StrokeThickness="2.2" StrokeStartLineCap="Round"/></Viewbox>
                            </Button>
                            <ProgressBar Height="3" Margin="8,0,8,5" VerticalAlignment="Bottom" Minimum="0" Maximum="100" Value="{Binding Progress}" Visibility="{Binding ProgressVisibility}" Foreground="{DynamicResource AccentBrush}" Background="Transparent"/>
                            <Button Tag="{Binding}" Content="重试" MinHeight="26" Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,5" Visibility="{Binding ErrorVisibility}" Style="{StaticResource SecondaryButton}" Click="RetryAttachmentButton_OnClick"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                  <TextBox x:Name="ChatInput" Grid.Row="2" MinHeight="42" MaxHeight="190" AcceptsReturn="True" TextWrapping="Wrap" Tag="向 AI 发送消息……"
                           Style="{StaticResource WatermarkTextBox}" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" Padding="8,6"
                           PreviewKeyDown="ChatInput_OnPreviewKeyDown" TextChanged="ChatInput_OnTextChanged"/>
                  <Grid Grid.Row="3" Margin="2,7,2,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Button x:Name="AttachmentUploadButton" Style="{StaticResource AttachmentToolbarButton}"
                              ToolTip="添加附件" AutomationProperties.Name="添加附件" Click="AttachmentUploadButton_OnClick">
                        <!-- Lucide Paperclip (24px), rendered as a vector for consistent DPI scaling. -->
                        <Viewbox Width="20" Height="20">
                          <Path Data="M16,6 L7.586,14.586 A2,2 0 0 0 10.415,17.415 L18.828,9 A4,4 0 0 0 13.171,3.343 L4.757,11.757 A6,6 0 0 0 13.243,20.243 L21.657,11.829"
                                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                      </Button>
                      <Button x:Name="ProjectPickerButton" MinHeight="32" Padding="9,5" Margin="0,0,8,0" Background="Transparent" Style="{StaticResource SecondaryButton}" ToolTip="选择项目目录" Click="ProjectPickerButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                          <Viewbox Width="15" Height="15" Margin="0,0,6,0"><Path Data="M3,6 H9 L11,8 H21 V19 A2,2 0 0 1 19,21 H3 A2,2 0 0 1 1,19 V8 A2,2 0 0 1 3,6 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" Fill="Transparent"/></Viewbox>
                          <TextBlock x:Name="ProjectPickerLabel" Text="项目空间" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                      <Button x:Name="WorkspaceAccessButton" MinHeight="32" Padding="9,5" Margin="0,0,8,0"
                              Visibility="Collapsed" Background="Transparent" Style="{StaticResource SecondaryButton}"
                              ToolTipService.ShowDuration="8000" Click="WorkspaceAccessButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                          <Viewbox Width="15" Height="15" Margin="0,0,6,0">
                            <Path Data="M12,2 L20,5 V11 C20,16.2 16.7,20.2 12,22 C7.3,20.2 4,16.2 4,11 V5 Z M9,12 L11,14 L15.5,9.5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                          </Viewbox>
                          <TextBlock x:Name="WorkspaceAccessLabel" Text="请求批准" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                      <Button x:Name="WebSearchToggleButton" MinHeight="32" Padding="9,5" Style="{StaticResource SecondaryButton}" ToolTip="点击关闭联网搜索" Click="WebSearchToggleButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                          <Viewbox Width="15" Height="15" Margin="0,0,6,0"><Path Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 0 1 12,2 M2,12 H22 M12,2 C16,6 16,18 12,22 M12,2 C8,6 8,18 12,22" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent"/></Viewbox>
                          <TextBlock x:Name="WebSearchToggleLabel" Text="联网开启" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button x:Name="StopGenerationButton" Visibility="Collapsed" Width="38" Height="38" MinHeight="38" Padding="10" Margin="0,0,7,0" Style="{StaticResource SecondaryButton}" ToolTip="停止生成" Click="StopGenerationButton_OnClick">
                        <Viewbox Width="14" Height="14"><Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/></Viewbox>
                      </Button>
                      <Button x:Name="ChatSendButton" Width="40" Height="40" MinHeight="40" Padding="10" IsEnabled="False" ToolTip="发送消息" AutomationProperties.Name="发送消息" Click="ChatSendButton_OnClick">
                        <ui:SymbolIcon Symbol="Send16" FontSize="18" Foreground="White"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Grid>
              </Border>
              <TextBlock Grid.Row="4" Text="GPT-5.6 可能会产生错误，请核查重要信息。" HorizontalAlignment="Center"
                         Foreground="{DynamicResource WeakTextBrush}" FontSize="11.5" Margin="24,0,24,14"/>
              <Border x:Name="AttachmentDropOverlay" Grid.RowSpan="5" Visibility="Collapsed" Panel.ZIndex="30"
                      Margin="12" CornerRadius="20" Background="{DynamicResource SecondarySurfaceBrush}" BorderBrush="{DynamicResource AccentBrush}"
                      BorderThickness="2" Opacity="0.97" IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <ui:SymbolIcon Symbol="ArrowUpload32" FontSize="42" HorizontalAlignment="Center" Foreground="{DynamicResource LinkBrush}"/>
                  <TextBlock Text="松开以上传文件" Margin="0,12,0,0" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}"/>
                  <TextBlock Text="支持一次拖入多个图片或文档" Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
              </Border>
              <Button x:Name="ShowSidebarButton" Grid.RowSpan="5" Panel.ZIndex="35" Visibility="Collapsed"
                      Width="40" Height="40" MinHeight="40" Padding="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="14" Style="{StaticResource IconToolbarButton}" ToolTip="展开侧栏（Ctrl+B）"
                      AutomationProperties.Name="展开侧栏" Click="ShowSidebarButton_OnClick">
                <ui:SymbolIcon Symbol="PanelLeftExpand20" FontSize="18"/>
              </Button>
              <Button x:Name="NewChatCollapsedButton" Grid.RowSpan="5" Panel.ZIndex="35" Visibility="Collapsed"
                      Width="40" Height="40" MinHeight="40" Padding="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="62,14,0,0" Style="{StaticResource IconToolbarButton}" ToolTip="新建会话（Ctrl+Shift+O）"
                      AutomationProperties.Name="新建会话" Click="NewChatButton_OnClick">
                <ui:SymbolIcon Symbol="ChatAdd20" FontSize="18"/>
              </Button>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="个人">
          <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource SecondarySurfaceBrush}">
            <StackPanel Margin="32,48,32,48" MaxWidth="760" HorizontalAlignment="Center">
              <Button Content="← 返回聊天" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="-4,0,0,22" Click="BackToChatButton_OnClick"/>
              <TextBlock Text="个人资料" FontSize="31" FontWeight="SemiBold"/>
              <TextBlock Text="管理头像和基本账户信息" FontSize="14" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,24"/>
              <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
                <StackPanel>
                  <Grid Margin="36,30">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="116"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Button x:Name="AvatarPreviewButton" Width="96" Height="96" Padding="0" HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" ToolTip="更换头像" AutomationProperties.Name="更换头像" Click="UploadAvatarButton_OnClick">
                      <Border Width="96" Height="96" CornerRadius="48" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Background="{DynamicResource SecondarySurfaceBrush}">
                        <Grid>
                          <TextBlock x:Name="ProfileAvatarFallbackText" Text="我" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                          <Border Background="#B30B1220" IsHitTestVisible="False">
                            <Border.Style><Style TargetType="Border"><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding IsMouseOver, ElementName=AvatarPreviewButton}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><ui:SymbolIcon Symbol="CameraEdit20" FontSize="22" Foreground="White"/><TextBlock Text="更换头像" Foreground="White" FontSize="11" Margin="0,5,0,0"/></StackPanel>
                          </Border>
                        </Grid>
                      </Border>
                    </Button>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock x:Name="ProfileNicknameHeading" Text="用户" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                      <TextBlock x:Name="ProfileEmailText" FontSize="14" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,10" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="点击头像即可更换 · 支持 JPG、PNG、WebP，最大 5 MB" FontSize="12" Foreground="{DynamicResource WeakTextBrush}"/>
                    </StackPanel>
                  </Grid>
                  <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                  <StackPanel Margin="36,28">
                    <TextBlock Text="基本资料" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="昵称" FontSize="14" FontWeight="Medium"/><TextBlock x:Name="NicknameCharacterCount" Grid.Column="1" Text="0/20" FontSize="12" Foreground="{DynamicResource WeakTextBrush}"/></Grid>
                    <TextBox x:Name="NicknameInput" Height="46" MaxLength="20" TextChanged="NicknameInput_OnTextChanged"/>
                    <TextBlock x:Name="NicknameValidationText" Visibility="Collapsed" Foreground="{DynamicResource ErrorBrush}" FontSize="12" Margin="2,6,0,0"/>
                    <TextBlock Text="邮箱" FontSize="14" FontWeight="Medium" Margin="0,20,0,8"/>
                    <Border Height="46" CornerRadius="10" Background="{DynamicResource SecondarySurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="13,0">
                      <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions><ui:SymbolIcon Symbol="LockClosed20" FontSize="16" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/><TextBlock x:Name="ProfileEmailReadonlyText" Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource MutedBrush}"/></Grid>
                    </Border>
                    <TextBlock Text="该邮箱已绑定，暂不支持修改" FontSize="12" Foreground="{DynamicResource WeakTextBrush}" Margin="2,6,0,0"/>
                  </StackPanel>
                  <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="36,18,36,20">
                    <Button x:Name="CancelProfileButton" Content="取消" MinWidth="78" Height="40" Style="{StaticResource OutlinedButton}" Visibility="Collapsed" Click="CancelProfileButton_OnClick"/>
                    <Button x:Name="SaveProfileButton" Content="保存更改" MinWidth="106" Height="40" Margin="10,0,0,0" Background="{DynamicResource AccentBrush}" Foreground="White" IsEnabled="False" Click="SaveProfileButton_OnClick"/>
                  </StackPanel>
                </StackPanel>
              </Border>
              <TextBlock Text="登录与账号" FontSize="16" FontWeight="SemiBold" Margin="2,26,0,11"/>
              <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="22,18">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel><TextBlock Text="退出登录" FontWeight="SemiBold"/><TextBlock Text="退出后，需要重新登录才能使用泺栋 Chat" FontSize="12.5" Foreground="{DynamicResource MutedBrush}" Margin="0,4,12,0"/></StackPanel>
                  <Button x:Name="LogoutButton" Grid.Column="1" Content="退出登录" MinWidth="88" Height="38" Style="{StaticResource OutlinedButton}" Click="LogoutButton_OnClick"/>
                </Grid>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
    <ui:SnackbarPresenter x:Name="GlobalSnackbarPresenter" Grid.RowSpan="3" Panel.ZIndex="200"
                          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="24,0,24,28"/>
  </Grid>
</Window>
