<Window x:Class="ChatGPTConnector.App.AvatarCropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="裁剪头像" Width="620" Height="650" MinWidth="560" MinHeight="610"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Background="{DynamicResource PageBackgroundBrush}" Foreground="{DynamicResource TextBrush}"
        ShowInTaskbar="False" UseLayoutRounding="True" SnapsToDevicePixels="True">
  <Grid Margin="30">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="裁剪头像" FontSize="26" FontWeight="SemiBold"/>
      <TextBlock Text="拖动图片调整位置，使用滑块缩放；头像将以方形图片保存。" Margin="0,7,0,0" FontSize="14" Foreground="{DynamicResource MutedBrush}"/>
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,24,0,18" HorizontalAlignment="Center" VerticalAlignment="Center">
      <Border Width="360" Height="360" CornerRadius="20" ClipToBounds="True" Background="#111827"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid x:Name="CropRenderSurface" Width="360" Height="360" ClipToBounds="True" Background="#111827"
              Cursor="SizeAll" MouseLeftButtonDown="CropSurface_OnMouseLeftButtonDown"
              MouseMove="CropSurface_OnMouseMove" MouseLeftButtonUp="CropSurface_OnMouseLeftButtonUp">
          <Image x:Name="SourceImage" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
              <TransformGroup>
                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                <RotateTransform x:Name="ImageRotation" Angle="0"/>
                <TranslateTransform x:Name="ImageTranslation" X="0" Y="0"/>
              </TransformGroup>
            </Image.RenderTransform>
          </Image>
        </Grid>
      </Border>
      <Ellipse Width="340" Height="340" Stroke="#E6FFFFFF" StrokeThickness="2" IsHitTestVisible="False"/>
    </Grid>

    <Grid Grid.Row="2" MaxWidth="460" HorizontalAlignment="Center">
      <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <ui:SymbolIcon Symbol="ZoomOut20" FontSize="18" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
      <Slider x:Name="ZoomSlider" Grid.Column="1" Minimum="1" Maximum="3" Value="1" TickFrequency="0.1" IsSnapToTickEnabled="False"
              VerticalAlignment="Center" ValueChanged="ZoomSlider_OnValueChanged"/>
      <ui:SymbolIcon Grid.Column="2" Symbol="ZoomIn20" FontSize="18" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="10,0,18,0"/>
      <Button Grid.Column="3" Content="旋转 90°" Height="38" Style="{StaticResource OutlinedButton}" Click="RotateButton_OnClick"/>
    </Grid>

    <Grid Grid.Row="3" Margin="0,26,0,0">
      <Button Content="重置" HorizontalAlignment="Left" Height="40" Style="{StaticResource OutlinedButton}" Click="ResetButton_OnClick"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="取消" MinWidth="78" Height="40" Style="{StaticResource OutlinedButton}" IsCancel="True"/>
        <Button Content="使用此头像" MinWidth="112" Height="40" Margin="10,0,0,0" Background="{DynamicResource AccentBrush}" Foreground="White" IsDefault="True" Click="ConfirmButton_OnClick"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
