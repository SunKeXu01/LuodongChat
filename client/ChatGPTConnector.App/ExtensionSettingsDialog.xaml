<Window x:Class="ChatGPTConnector.App.ExtensionSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="MCP 与 Skills" Width="920" Height="680" MinWidth="760" MinHeight="560"
        Icon="/LuodongChat;component/Assets/AppIcon.png"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        ShowInTaskbar="False" Background="{DynamicResource PageBackgroundBrush}" Foreground="{DynamicResource TextBrush}">
  <Grid Margin="30,26,30,24">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="MCP 与 Skills" FontSize="29" FontWeight="SemiBold"/>
      <TextBlock Text="连接外部工具，并为 GPT 安装可复用的专业工作流程。所有第三方 MCP 工具首次调用都会请求确认。"
                 Margin="0,7,0,20" FontSize="14" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
    </StackPanel>

    <TabControl Grid.Row="1" x:Name="ExtensionTabs" Background="Transparent" BorderThickness="0">
      <TabItem Header="MCP 服务器">
        <Grid Margin="0,18,0,0">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="外部工具服务器" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="支持 stdio、Streamable HTTP 与旧版 SSE。stdio 进程只获得最小系统环境变量。"
                         Margin="0,4,20,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Button Content="发现 MCP" Height="40" Padding="15,0" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="DiscoverMcpButton_OnClick"/>
              <Button Content="＋ 添加服务器" Height="40" Padding="15,0" Click="AddMcpButton_OnClick"/>
              <Button Content="重新连接" Height="40" Padding="15,0" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="ReconnectMcpButton_OnClick"/>
            </StackPanel>
          </Grid>
          <Border Grid.Row="1" Margin="0,18,0,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
            <ListBox x:Name="McpServersList" BorderThickness="0" Background="Transparent" Padding="8" HorizontalContentAlignment="Stretch">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="7,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="2,0,12,0" Click="McpEnabled_OnClick"/>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding EndpointSummary}" Margin="0,3,0,0" Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding TransportLabel}" Foreground="{DynamicResource MutedBrush}"/>
                      <TextBlock Text="{Binding StatusText}" Margin="0,3,0,0" Foreground="{DynamicResource LinkBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="编辑" Padding="12,6" Style="{StaticResource SecondaryButton}" Tag="{Binding}" Click="EditMcpButton_OnClick"/>
                      <Button Content="删除" Padding="12,6" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Tag="{Binding}" Click="DeleteMcpButton_OnClick"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
          <TextBlock Grid.Row="2" x:Name="McpNotice" Margin="2,12,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
        </Grid>
      </TabItem>

      <TabItem Header="Skills">
        <Grid Margin="0,18,0,0">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="已安装技能" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="兼容 Codex/Agent Skills 的 SKILL.md。启用后自动提供给 GPT，也可在消息中使用 $skill-name。"
                         Margin="0,4,20,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Button Content="从文件夹安装" Height="40" Padding="15,0" Click="InstallSkillButton_OnClick"/>
              <Button Content="打开技能目录" Height="40" Padding="15,0" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="OpenSkillsFolderButton_OnClick"/>
            </StackPanel>
          </Grid>
          <Border Grid.Row="1" Margin="0,18,0,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
            <ListBox x:Name="SkillsList" BorderThickness="0" Background="Transparent" Padding="8" HorizontalContentAlignment="Stretch">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="7,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="2,0,12,0" Click="SkillEnabled_OnClick"/>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Description}" Margin="0,3,20,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" MaxHeight="42"/>
                      <TextBlock Text="{Binding FileSummary}" Margin="0,4,0,0" Foreground="{DynamicResource WeakTextBrush}" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="删除" Padding="12,6" Style="{StaticResource SecondaryButton}" Tag="{Binding}" Click="DeleteSkillButton_OnClick" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
          <TextBlock Grid.Row="2" x:Name="SkillNotice" Margin="2,12,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
        </Grid>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
      <Button Content="完成" MinWidth="90" Height="40" Click="CloseButton_OnClick"/>
    </StackPanel>
  </Grid>
</Window>
