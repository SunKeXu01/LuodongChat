<ui:FluentWindow x:Class="ChatGPTConnector.App.WorkspacePermissionSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="自定义项目权限" Width="650" Height="560" MinWidth="580" MinHeight="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        WindowBackdropType="None" WindowCornerPreference="Round"
        Background="{DynamicResource PageBackgroundBrush}" Foreground="{DynamicResource TextBrush}"
        ShowInTaskbar="False">
  <Grid Margin="30">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="自定义项目权限" FontSize="26" FontWeight="SemiBold"/>
      <TextBlock Text="分别决定 GPT 对当前项目的各类操作是自动允许、每次询问还是始终禁止。"
                 Margin="0,8,0,0" FontSize="14" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
    </StackPanel>
    <StackPanel Grid.Row="1" Margin="0,24,0,0">
      <Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Text="读取项目文件" FontSize="15" FontWeight="SemiBold"/><TextBlock Text="列出、搜索和读取已选择目录中的非敏感文件" Margin="0,4,18,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/></StackPanel>
        <ComboBox x:Name="ReadDecision" Grid.Column="1" Height="40"/>
      </Grid>
      <Separator/>
      <Grid Margin="0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Text="编辑项目文件" FontSize="15" FontWeight="SemiBold"/><TextBlock Text="创建、覆盖、替换和移动项目文件" Margin="0,4,18,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/></StackPanel>
        <ComboBox x:Name="WriteDecision" Grid.Column="1" Height="40"/>
      </Grid>
      <Separator/>
      <Grid Margin="0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Text="联网与下载" FontSize="15" FontWeight="SemiBold"/><TextBlock Text="使用 curl、wget、Git 或其他命令访问互联网" Margin="0,4,18,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/></StackPanel>
        <ComboBox x:Name="NetworkDecision" Grid.Column="1" Height="40"/>
      </Grid>
      <Separator/>
      <Grid Margin="0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Text="危险操作" FontSize="15" FontWeight="SemiBold"/><TextBlock Text="删除文件、远程发布、重置版本库等不可轻易撤销的操作" Margin="0,4,18,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/></StackPanel>
        <ComboBox x:Name="DestructiveDecision" Grid.Column="1" Height="40"/>
      </Grid>
      <TextBlock Text="提权、修改系统账户、关机和关键系统设置始终禁止，不能在此关闭。"
                 Margin="0,8,0,0" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
    </StackPanel>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
      <Button Content="取消" MinWidth="82" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="CancelButton_OnClick"/>
      <Button Content="保存设置" MinWidth="104" Height="40" Click="SaveButton_OnClick"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
